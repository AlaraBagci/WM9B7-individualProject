    "# Reload all models from disk for profiling\nmodel_baseline = BaselineCNN(NUM_CLASSES).to(DEVICE)\nmodel_baseline.load_state_dict(torch.load(\"/tmp/baseline_weights.pt\", map_location=DEVICE))\nmodel_baseline.eval()\n\nmodel_effnet = timm.create_model(\"efficientnet_b0\", pretrained=False, num_classes=NUM_CLASSES).to(DEVICE)\nmodel_effnet.load_state_dict(torch.load(\"/tmp/effnet_weights.pt\", map_location=DEVICE))\nmodel_effnet.eval()\n\nmodel_convnext = timm.create_model(\"convnext_tiny\", pretrained=False, num_classes=NUM_CLASSES).to(DEVICE)\nmodel_convnext.load_state_dict(torch.load(\"/tmp/convnext_weights.pt\", map_location=DEVICE))\nmodel_convnext.eval()\n\n# ============================================================\n# Deployment Profiling: Params, Size, Inference Time\n# ============================================================\n\ndef profile_model(model, model_name, device, input_size=(1, 3, 224, 224), n_runs=50):\n    model.eval()\n    dummy = torch.randn(*input_size).to(device)\n\n    # Warm-up\n    with torch.no_grad():\n        for _ in range(10):\n            model(dummy)\n\n    # Measure inference time (CPU for fair mobile comparison)\n    model_cpu = model.cpu()\n    dummy_cpu = dummy.cpu()\n\n    times = []\n    with torch.no_grad():\n        for _ in range(n_runs):\n            start = time.time()\n            model_cpu(dummy_cpu)\n            times.append((time.time() - start) * 1000)  # ms\n\n    model.to(device)  # Move back\n\n    params = sum(p.numel() for p in model.parameters())\n    size_mb = params * 4 / (1024 ** 2)  # float32\n    avg_time = np.mean(times)\n    std_time = np.std(times)\n\n    return {\n        \"name\": model_name,\n        \"params\": params,\n        \"size_mb\": size_mb,\n        \"avg_time_ms\": avg_time,\n        \"std_time_ms\": std_time\n    }\n\nprofiles = [\n    profile_model(model_baseline, \"Baseline CNN\", DEVICE),\n    profile_model(model_effnet, \"EfficientNet-B0\", DEVICE),\n    profile_model(model_convnext, \"ConvNeXt-Tiny\", DEVICE),\n]\n\n# --- Print Table ---\nprint(f\"{'='*80}\")\nprint(f\"{'Model':<20} {'Params':>12} {'Size (MB)':>10} {'Inference (ms)':>16} {'Mobile?':>10}\")\nprint(f\"{'-'*80}\")\nfor p in profiles:\n    mobile = \"Yes\" if p[\"size_mb\"] < 30 else \"No\"\n    print(f\"{p['name']:<20} {p['params']:>12,} {p['size_mb']:>9.1f} \"\n          f\"{p['avg_time_ms']:>10.1f} \u00b1 {p['std_time_ms']:.1f} {mobile:>10}\")\nprint(f\"{'='*80}\")\n\n# --- Accuracy vs Size Scatter ---\nfig, ax = plt.subplots(figsize=(10, 6))\n\nfor p, (name, m) in zip(profiles, all_results.items()):\n    ax.scatter(p[\"size_mb\"], m[\"accuracy\"], s=200, zorder=5, edgecolors=\"black\")\n    ax.annotate(name, (p[\"size_mb\"], m[\"accuracy\"]),\n                textcoords=\"offset points\", xytext=(10, 10), fontsize=11, fontweight=\"bold\")\n\nax.axhline(y=89.19, color=\"red\", linestyle=\"--\", alpha=0.7,\n           label=\"Paper best: 89.19% (Inception V3)\")\nax.axvline(x=30, color=\"green\", linestyle=\"--\", alpha=0.7,\n           label=\"Mobile threshold (~30 MB)\")\n\nax.set_xlabel(\"Model Size (MB)\", fontsize=12)\nax.set_ylabel(\"Test Accuracy (%)\", fontsize=12)\nax.set_title(\"Accuracy vs Model Size \u2014 Deployment Spectrum\", fontsize=14, fontweight=\"bold\")\nax.legend(fontsize=10)\nax.grid(alpha=0.3)\nplt.tight_layout()\nplt.show()\n\nprint(\"\\nDeployment recommendation:\")\nprint(f\"  Mobile app (SortSmart):  EfficientNet-B0 ({profiles[1]['size_mb']:.0f} MB, \"\n      f\"{all_results['EfficientNet-B0']['accuracy']:.2f}% acc)\")\nprint(f\"  MRF industrial:          ConvNeXt-Tiny ({profiles[2]['size_mb']:.0f} MB, \"\n      f\"{all_results['ConvNeXt-Tiny']['accuracy']:.2f}% acc)\")\nprint(f\"  Future: Knowledge distillation could bridge this gap\")\n\n\n# Free all models after profiling\ndel model_baseline, model_effnet, model_convnext\nclear_gpu()\nprint(\"All models freed after profiling\")\n"
