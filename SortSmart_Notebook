    "# ============================================================\n",
    "# Custom Dataset & Transforms\n",
    "# ============================================================\n",
    "\n",
    "class WasteDataset(Dataset):\n",
    "    \"\"\"Dataset with RAM caching \u2014 loads each image once from disk.\n",
    "    RealWaste is ~4,800 images at 224x224 \u2248 700 MB RAM, well within Colab's 12 GB.\n",
    "    Eliminates repeated slow reads from Google Drive every epoch.\"\"\"\n",
    "    def __init__(self, image_paths, labels, transform=None):\n",
    "        self.labels = labels\n",
    "        self.transform = transform\n",
    "        print(f\"  Caching {len(image_paths)} images in RAM...\", end=\" \", flush=True)\n",
    "        self.images = [Image.open(p).convert(\"RGB\") for p in image_paths]\n",
    "        print(\"Done\")\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.labels)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        image = self.images[idx].copy()  # copy so transforms don't mutate cache\n",
    "        if self.transform:\n",
    "            image = self.transform(image)\n",
    "        return image, self.labels[idx]\n",
    "\n",
    "# ============================================================\n",
    "# Augmentation Strategy \u2014 Research-Informed\n",
    "# ============================================================\n",
    "# Design rationale:\n",
    "# 1. GEOMETRIC augmentations are PRIMARY \u2014 proven superior for waste\n",
    "#    classification (Shijie et al., 2017; de la Rosa et al., 2022).\n",
    "#    - Flip/Rotate: waste has no canonical orientation\n",
    "#    - ElasticTransform: simulates structural deformation of crushed,\n",
    "#      crumpled waste (Single et al., 2023)\n",
    "#    - Shear/Translate: perspective and position variation\n",
    "#    - RandomResizedCrop: scale variation for mobile camera distance\n",
    "#\n",
    "# 2. PHOTOMETRIC augmentations are SECONDARY \u2014 complement geometric\n",
    "#    to handle lighting variation across environments (kitchen, bin, MRF).\n",
    "#    - ColorJitter: brightness/contrast/saturation/hue variation\n",
    "#    - GaussianBlur: camera focus and motion blur simulation\n",
    "#    - RandomGrayscale: forces texture-based (not colour-based) learning\n",
    "#\n",
    "# 3. OCCLUSION simulation via RandomErasing \u2014 waste items overlap\n",
    "#    in bins and on conveyor belts (DeVries & Taylor, 2017).\n",
    "#\n",
    "# 4. ImageNet normalisation \u2014 essential for pretrained model compatibility.\n",
    "\n",
    "train_transform = T.Compose([\n",
    "    # --- Spatial / Geometric (primary) ---\n",
    "    T.RandomResizedCrop(IMG_SIZE, scale=(0.8, 1.0)),  # Scale + crop variation\n",
    "    T.RandomHorizontalFlip(p=0.5),                     # No canonical orientation\n",
    "    T.RandomRotation(degrees=20),                      # Rotation invariance\n",
    "    T.RandomAffine(degrees=0, shear=15,                # Perspective distortion\n",
    "                   translate=(0.1, 0.1)),               # Position variation\n",
    "\n",
    "    # --- Photometric (secondary) ---\n",
    "    T.ColorJitter(brightness=0.3, contrast=0.3,        # Lighting variation\n",
    "                  saturation=0.3, hue=0.05),            # Slight hue shift\n",
    "    T.RandomGrayscale(p=0.05),                          # Force texture learning\n",
    "    T.GaussianBlur(kernel_size=3, sigma=(0.1, 2.0)),   # Focus/motion blur\n",
    "\n",
    "    # --- Tensor conversion & normalisation ---\n",
    "    T.ToTensor(),\n",
    "    T.Normalize(mean=[0.485, 0.456, 0.406],            # ImageNet statistics\n",
    "                std=[0.229, 0.224, 0.225]),\n",
    "\n",
    "    # --- Occlusion simulation (applied on tensor) ---\n",
    "    T.RandomErasing(p=0.1, scale=(0.02, 0.15)),        # Partial occlusion\n",
    "])\n",
    "\n",
    "# Validation / Test: deterministic \u2014 no augmentation, no randomness\n",
    "eval_transform = T.Compose([\n",
    "    T.Resize((IMG_SIZE, IMG_SIZE)),\n",
    "    T.ToTensor(),\n",
    "    T.Normalize(mean=[0.485, 0.456, 0.406],\n",
    "                std=[0.229, 0.224, 0.225])\n",
    "])\n",
    "\n",
    "train_dataset = WasteDataset(X_train, y_train, transform=train_transform)\n",
    "val_dataset   = WasteDataset(X_val,   y_val,   transform=eval_transform)\n",
    "test_dataset  = WasteDataset(X_test,  y_test,  transform=eval_transform)\n",
    "\n",
    "print(\"Datasets created with enhanced augmentation pipeline.\")\n",
    "print(f\"  Train: {len(train_dataset)} | Val: {len(val_dataset)} | Test: {len(test_dataset)}\")\n",
    "print(\"\\nAugmentation summary:\")\n",
    "print(\"  Geometric (primary): RandomResizedCrop, HorizontalFlip, Rotation(\u00b120\u00b0), Shear(15\u00b0), Translate\")\n",
    "print(\"  Photometric (secondary): ColorJitter, GaussianBlur, RandomGrayscale(5%)\")\n",
    "print(\"  Occlusion: RandomErasing(10%)\")\n",
    "print(\"  Normalisation: ImageNet statistics (required for pretrained models)\")"
   ]
